void saveMoviesToFile(MovieList& list) {
    ofstream file("movies.txt");
    if (!file.is_open()) {
        cout << "[ERROR] Cannot open movies.txt for writing.\n";
        return;
    }
    MovieNode* curr = list.getHead();
    while (curr != NULL) {
        file << curr->data.movieID << "|"
             << curr->data.title   << "|"
             << curr->data.genre   << "|"
             << curr->data.price   << "|"
             << curr->data.rating  << "\n";
        curr = curr->next;
    }
    file.close();
}
void loadMoviesFromFile(MovieList& list) {
    ifstream file("movies.txt");
    if (!file.is_open()) return;
    string line;
    while (getline(file, line)) {
        if (line.empty()) continue;
        istringstream ss(line);
        string part;
        int id;
        string title, genre;
        double price, rating;
        try {
            getline(ss, part, '|'); id     = stringToInt(part);
            getline(ss, title,  '|');
            getline(ss, genre,  '|');
            getline(ss, part,   '|'); price  = stringToDouble(part);
            getline(ss, part,   '|'); rating = stringToDouble(part);
            list.insertMovie(id, title, genre, price, rating);
        } catch (...) {
        }
    }
    file.close();
}
