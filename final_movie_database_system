void displayTopRatedMovies(MovieList& list, int topN) {
    if (list.getHead() == NULL) {
        cout << "  No movies available.\n";
        return;
    }
    int n = list.getCount();
    if (topN > n) topN = n;
    MovieNode** temp = new MovieNode*[n];
    MovieNode* curr = list.getHead();
    for (int i = 0; i < n; i++) {
        temp[i] = curr;
        curr = curr->next;
    }
    for (int i = 0; i < n - 1; i++) {
        int maxIdx = i;
        for (int j = i + 1; j < n; j++) {
            if (temp[j]->data.rating > temp[maxIdx]->data.rating)
                maxIdx = j;
        }
        if (maxIdx != i) {
            MovieNode* t = temp[i];
            temp[i] = temp[maxIdx];
            temp[maxIdx] = t;
        }
    }
    cout << "\n--- Top " << topN << " Highest Rated Movies ---\n";
    cout << left << setw(5) << "Rank"
         << setw(8)  << "ID"
         << setw(35) << "Title"
         << setw(15) << "Genre"
         << "Rating\n";
    cout << string(65, '-') << "\n";
    for (int i = 0; i < topN; i++) {
        cout << left << setw(5) << (i+1)
             << setw(8)  << temp[i]->data.movieID
             << setw(35) << temp[i]->data.title
             << setw(15) << temp[i]->data.genre
             << temp[i]->data.rating << "/10\n";
    }
    cout << string(65, '-') << "\n";
    delete[] temp;
}
