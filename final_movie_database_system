int nextBookingID = 5001;  
void customerBookTicket(MovieList& list, BookingData* arr, int& total,
                        string username, double discountRate) {
    cout << "\n--- Book Tickets ---\n";
    list.displayAll();
    int id;
    cout << "Enter Movie ID to book: ";
    try {
        cin >> id;
        if (cin.fail()) {
            cin.clear(); cin.ignore(1000, '\n');
            throw invalid_argument("Invalid input.");
        }
    } catch (exception& e) {
        cout << "[ERROR] " << e.what() << "\n";
        cin.ignore(1000, '\n');
        return;
    }
    cin.ignore(1000, '\n');
    MovieNode* movie = list.findMovie(id);
    if (movie == NULL) {
        cout << "  Movie not found.\n";
        return;
    }
    cout << "  Movie : " << movie->data.title << "\n";
    cout << "  Price : RM" << fixed << setprecision(2) << movie->data.price << " per ticket\n";
    int qty;
    cout << "Number of tickets: ";
    try {
        cin >> qty;
        if (cin.fail()) {
            cin.clear(); cin.ignore(1000, '\n');
            throw invalid_argument("Invalid quantity.");
        }
        if (qty <= 0) throw invalid_argument("Quantity must be at least 1.");
        if (qty > 20) throw out_of_range("Maximum 20 tickets per booking.");
    } catch (exception& e) {
        cout << "[ERROR] " << e.what() << "\n";
        cin.ignore(1000, '\n');
        return;
    }
    cin.ignore(1000, '\n');
    double base    = movie->data.price * qty;
    double disc    = base * discountRate;
    double total_p = base - disc;
    if (total >= 200) {
        cout << "  [ERROR] Booking limit reached.\n";
        return;
    }
    arr[total].bookingID    = nextBookingID++;
    arr[total].customerName = username;
    arr[total].movieID      = id;
    arr[total].movieTitle   = movie->data.title;
    arr[total].quantity     = qty;
    arr[total].totalPrice   = total_p;
    saveBookingToFile(arr[total]);
    total++;
    cout << "\n  --- Booking Confirmation ---\n";
    cout << "  Booking ID: " << (nextBookingID - 1) << "\n";
    cout << "  Movie     : " << movie->data.title << "\n";
    cout << "  Tickets   : " << qty << "\n";
    cout << "  Base Price: RM" << fixed << setprecision(2) << base << "\n";
    if (discountRate > 0) {
        cout << "  VIP Disc  : -RM" << disc << " (" << (discountRate * 100) << "% off)\n";
    }
    cout << "  Total     : RM" << fixed << setprecision(2) << total_p << "\n";
    cout << "  Booking confirmed!\n";
}
void customerViewMyBookings(BookingData* arr, int total, string username) {
    cout << "\n--- My Bookings (" << username << ") ---\n";
    int found = 0;
    double myTotal = 0.0;
    cout << left << setw(6)  << "BID"
         << setw(28) << "Movie"
         << setw(5)  << "Qty"
         << "Amount\n";
    cout << string(50, '-') << "\n";
    for (int i = 0; i < total; i++) {
        string cname = arr[i].customerName;
        if (cname.length() > 5 && cname.substr(cname.length()-5) == "(VIP)")
            cname = cname.substr(0, cname.length()-5);
        if (cname == username) {
            cout << left << setw(6)  << arr[i].bookingID
                 << setw(28) << arr[i].movieTitle
                 << setw(5)  << arr[i].quantity
                 << "RM" << fixed << setprecision(2) << arr[i].totalPrice << "\n";
            myTotal += arr[i].totalPrice;
            found++;
        }
    }
    if (found == 0) cout << "  No bookings found.\n";
    else {
        cout << string(50, '-') << "\n";
        cout << "  Total spent: RM" << fixed << setprecision(2) << myTotal << "\n";
    }
}
void customerEditBooking(BookingData* arr, int& total, string username, MovieList& list) {
    cout << "\n--- Edit My Booking ---\n";
    customerViewMyBookings(arr, total, username);
    int bid;
    cout << "Enter Booking ID to edit: ";
    try {
        cin >> bid;
        if (cin.fail()) {
            cin.clear(); cin.ignore(1000, '\n');
            throw invalid_argument("Invalid booking ID.");
        }
    } catch (exception& e) {
        cout << "[ERROR] " << e.what() << "\n";
        cin.ignore(1000, '\n');
        return;
    }
    cin.ignore(1000, '\n');
    int index = -1;
    for (int i = 0; i < total; i++) {
        string cname = arr[i].customerName;
        if (cname.length() > 5 && cname.substr(cname.length()-5) == "(VIP)")
            cname = cname.substr(0, cname.length()-5);
        if (arr[i].bookingID == bid && cname == username) {
            index = i;
            break;
        }
    }
    if (index == -1) {
        cout << "  Booking not found or not yours.\n";
        return;
    }
    cout << "Booking: " << arr[index].movieTitle
         << " x" << arr[index].quantity
         << " = RM" << fixed << setprecision(2) << arr[index].totalPrice << "\n";
    cout << "1. Change quantity\n2. Cancel booking\n3. Go back\nChoice: ";
    int choice;
    cin >> choice;
    cin.ignore(1000, '\n');
    if (choice == 1) {
        int newQty;
        cout << "New quantity (1-20): ";
        try {
            cin >> newQty;
            if (cin.fail()) {
                cin.clear(); cin.ignore(1000, '\n');
                throw invalid_argument("Invalid quantity.");
            }
            if (newQty <= 0 || newQty > 20)
                throw out_of_range("Quantity must be 1 to 20.");
        } catch (exception& e) {
            cout << "[ERROR] " << e.what() << "\n";
            cin.ignore(1000, '\n');
            return;
        }
        cin.ignore(1000, '\n');
        MovieNode* movie = list.findMovie(arr[index].movieID);
        if (movie == NULL) {
            cout << "  Movie no longer in database.\n";
            return;
        }
        arr[index].quantity   = newQty;
        arr[index].totalPrice = movie->data.price * newQty;
        rewriteBookingsFile(arr, total);
        cout << "  Booking updated. New total: RM"
             << fixed << setprecision(2) << arr[index].totalPrice << "\n";
    } else if (choice == 2) {
        for (int i = index; i < total - 1; i++) {
            arr[i] = arr[i+1];
        }
        total--;
        rewriteBookingsFile(arr, total);
        cout << "  Booking cancelled.\n";
    } else {
        cout << "  No changes made.\n";
    }
}
