void loadBookingsFromFile(BookingData* arr, int& total) {
    ifstream file("bookings.txt");
    if (!file.is_open()) return;
    string line;
    while (getline(file, line) && total < 200) {
        if (line.empty()) continue;
        istringstream ss(line);
        string part;
        try {
            getline(ss, part, '|'); arr[total].bookingID    = stringToInt(part);
            getline(ss, arr[total].customerName, '|');
            getline(ss, part, '|'); arr[total].movieID      = stringToInt(part);
            getline(ss, arr[total].movieTitle, '|');
            getline(ss, part, '|'); arr[total].quantity     = stringToInt(part);
            getline(ss, part, '|'); arr[total].totalPrice   = stringToDouble(part);
            total++;
        } catch (...) {
        }
    }
    file.close();
}
