struct ReviewData {
    int reviewID;
    string customerName;
    int movieID;
    string movieTitle;
    int stars;          
    string comment;
};
void saveReviewToFile(ReviewData& r) {
    ofstream file("reviews.txt", ios::app);
    if (!file.is_open()) {
        cout << "  [ERROR] Cannot open reviews.txt.\n";
        return;
    }
    file << r.reviewID    << "|"
         << r.customerName << "|"
         << r.movieID      << "|"
         << r.movieTitle   << "|"
         << r.stars        << "|"
         << r.comment      << "\n";
    file.close();
}
void loadReviewsFromFile(ReviewData* arr, int& total) {
    ifstream file("reviews.txt");
    if (!file.is_open()) return;
    string line;
    while (getline(file, line) && total < 300) {
        if (line.empty()) continue;
        istringstream ss(line);
        string part;
        try {
            getline(ss, part, '|'); arr[total].reviewID     = stringToInt(part);
            getline(ss, arr[total].customerName, '|');
            getline(ss, part, '|'); arr[total].movieID      = stringToInt(part);
            getline(ss, arr[total].movieTitle,   '|');
            getline(ss, part, '|'); arr[total].stars        = stringToInt(part);
            getline(ss, arr[total].comment,      '|');
            total++;
        } catch (...) {
        }
    }
    file.close();
}
