void displayBookingStatistics(BookingData* arr, int total, MovieList& list) {
    if (total == 0) {
        cout << "  No booking data yet.\n";
        return;
    }
    double grandTotal  = 0.0;
    int    maxQty      = 0;
    int    bestIdx     = 0;
    double maxRevenue  = 0.0;
    int    bestRevIdx  = 0;
    int   movieIDs[200];
    int   movieCount[200];
    double movieRevenue[200];
    int   uniqueMovies = 0;
    for (int i = 0; i < total; i++) {
        grandTotal += arr[i].totalPrice;
        if (arr[i].quantity > maxQty) {
            maxQty   = arr[i].quantity;
            bestIdx  = i;
        }
        bool found = false;
        for (int j = 0; j < uniqueMovies; j++) {
            if (movieIDs[j] == arr[i].movieID) {
                movieCount[j]   += arr[i].quantity;
                movieRevenue[j] += arr[i].totalPrice;
                found = true;
                break;
            }
        }
        if (!found && uniqueMovies < 200) {
            movieIDs[uniqueMovies]     = arr[i].movieID;
            movieCount[uniqueMovies]   = arr[i].quantity;
            movieRevenue[uniqueMovies] = arr[i].totalPrice;
            uniqueMovies++;
        }
    }
    int maxTickets  = 0;
    int popularIdx  = 0;
    for (int i = 0; i < uniqueMovies; i++) {
        if (movieCount[i] > maxTickets) {
            maxTickets  = movieCount[i];
            popularIdx  = i;
        }
        if (movieRevenue[i] > maxRevenue) {
            maxRevenue  = movieRevenue[i];
            bestRevIdx  = i;
        }
    }
    cout << "\n=== Booking Statistics ===\n";
    cout << "Total Bookings    : " << total << "\n";
    cout << "Grand Total Sales : RM" << fixed << setprecision(2) << grandTotal << "\n";
    cout << "Avg per Booking   : RM" << fixed << setprecision(2) << (grandTotal / total) << "\n";
    cout << "Unique Movies Sold: " << uniqueMovies << "\n";
    if (uniqueMovies > 0) {
        MovieNode* popularMovie = list.findMovie(movieIDs[popularIdx]);
        string popularTitle = (popularMovie != NULL) ? popularMovie->data.title : "Unknown";
        MovieNode* topRevMovie  = list.findMovie(movieIDs[bestRevIdx]);
        string topRevTitle  = (topRevMovie  != NULL) ? topRevMovie->data.title  : "Unknown";
        cout << "Most Popular Movie: " << popularTitle
             << " (" << maxTickets << " tickets)\n";
        cout << "Top Revenue Movie : " << topRevTitle
             << " (RM" << fixed << setprecision(2) << maxRevenue << ")\n";
    }
    cout << "Largest Single Booking: Booking #" << arr[bestIdx].bookingID
         << " by " << arr[bestIdx].customerName
         << " (" << maxQty << " tickets)\n";
    cout << "==========================\n";
}
