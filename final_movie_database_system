void staffAddMovie(MovieList& list) {
    cout << "\n--- Add New Movie ---\n";
    int id;
    string title, genre;
    double price, rating;
    cout << "Enter Movie ID (4 digits, e.g. 1066): ";
    try {
        cin >> id;
        if (cin.fail()) {
            cin.clear(); cin.ignore(1000, '\n');
            throw invalid_argument("Invalid ID input.");
        }
        if (!checkInput(id))
            throw out_of_range("ID must be between 1000 and 9999.");
        if (list.findMovie(id) != NULL)
            throw runtime_error("A movie with this ID already exists.");
    } catch (exception& e) {
        cout << "[ERROR] " << e.what() << "\n";
        cin.ignore(1000, '\n');
        return;
    }
    cin.ignore(1000, '\n');
    cout << "Enter Title: ";
    getline(cin, title);
    if (!checkInput(title)) { cout << "[ERROR] Title cannot be empty.\n"; return; }
    cout << "Enter Genre (Action/Drama/Sci-Fi/etc): ";
    getline(cin, genre);
    if (!checkInput(genre)) { cout << "[ERROR] Genre cannot be empty.\n"; return; }
    cout << "Enter Price (RM): ";
    try {
        cin >> price;
        if (cin.fail()) {
            cin.clear(); cin.ignore(1000, '\n');
            throw invalid_argument("Invalid price input.");
        }
        if (!checkInput(price))
            throw out_of_range("Price must be between 0.01 and 999.99.");
    } catch (exception& e) {
        cout << "[ERROR] " << e.what() << "\n";
        cin.ignore(1000, '\n');
        return;
    }
    cout << "Enter Rating (0.1 - 10.0): ";
    try {
        cin >> rating;
        if (cin.fail()) {
            cin.clear(); cin.ignore(1000, '\n');
            throw invalid_argument("Invalid rating input.");
        }
        if (rating < 0.1 || rating > 10.0)
            throw out_of_range("Rating must be between 0.1 and 10.0.");
    } catch (exception& e) {
        cout << "[ERROR] " << e.what() << "\n";
        cin.ignore(1000, '\n');
        return;
    }
    cin.ignore(1000, '\n');
    list.insertMovie(id, title, genre, price, rating);
    saveMoviesToFile(list);
    cout << "  Movie added successfully!\n";
}
void staffEditMovie(MovieList& list) {
    cout << "\n--- Edit Movie ---\n";
    list.displayAll();
    int id;
    cout << "Enter Movie ID to edit: ";
    try {
        cin >> id;
        if (cin.fail()) {
            cin.clear(); cin.ignore(1000, '\n');
            throw invalid_argument("Invalid ID input.");
        }
    } catch (exception& e) {
        cout << "[ERROR] " << e.what() << "\n";
        cin.ignore(1000, '\n');
        return;
    }
    cin.ignore(1000, '\n');
    MovieNode* node = list.findMovie(id);
    if (node == NULL) {
        cout << "  Movie ID " << id << " not found.\n";
        return;
    }
    cout << "Current: " << node->data.title << " | " << node->data.genre
         << " | RM" << node->data.price << " | " << node->data.rating << "/10\n";
    cout << "What to edit?\n";
    cout << "1. Title\n2. Genre\n3. Price\n4. Rating\n5. Cancel\n";
    cout << "Choice: ";
    int choice;
    cin >> choice;
    cin.ignore(1000, '\n');
    try {
        if (choice == 1) {
            cout << "New title: ";
            string t; getline(cin, t);
            if (!checkInput(t)) throw invalid_argument("Title cannot be empty.");
            node->data.title = t;
        } else if (choice == 2) {
            cout << "New genre: ";
            string g; getline(cin, g);
            if (!checkInput(g)) throw invalid_argument("Genre cannot be empty.");
            node->data.genre = g;
        } else if (choice == 3) {
            cout << "New price (RM): ";
            double p; cin >> p;
            if (cin.fail() || !checkInput(p)) throw invalid_argument("Invalid price.");
            cin.ignore(1000, '\n');
            node->data.price = p;
        } else if (choice == 4) {
            cout << "New rating (0.1-10.0): ";
            double r; cin >> r;
            if (cin.fail() || r < 0.1 || r > 10.0) throw invalid_argument("Invalid rating.");
            cin.ignore(1000, '\n');
            node->data.rating = r;
        } else {
            cout << "  Edit cancelled.\n";
            return;
        }
    } catch (exception& e) {
        cout << "[ERROR] " << e.what() << "\n";
        cin.ignore(1000, '\n');
        return;
    }
    saveMoviesToFile(list);
    cout << "  Movie updated successfully!\n";
}
