            reviewIDCounter = allReviews[i].reviewID + 1;
    }
    cout << "  Movies loaded  : " << movieDB.getCount() << "\n";
    cout << "  Bookings loaded: " << bookingTotal << "\n";
    cout << "  Reviews loaded : " << reviewTotal  << "\n";
    cout << "  System ready!\n";
    int mainChoice = -1;
    while (mainChoice != 0) {
        printHeader("MAIN MENU");
        cout << "  1. Staff / Admin Login\n";
        cout << "  2. Customer Login\n";
        cout << "  3. Customer Registration\n";
        cout << "  4. VIP Customer Login\n";
        cout << "  0. Exit\n";
        printLine(44);
        cout << "  Choice: ";
        try {
            cin >> mainChoice;
            if (cin.fail()) {
                cin.clear(); cin.ignore(1000, '\n');
                throw invalid_argument("Please enter a number.");
            }
            if (!checkInput(mainChoice, 0, 4))
                throw out_of_range("Choice must be 0 to 4.");
        } catch (exception& e) {
            cout << "[ERROR] " << e.what() << "\n";
            cin.clear(); cin.ignore(1000, '\n');
            continue;
        }
        cin.ignore(1000, '\n');
        if (mainChoice == 1) {
            runStaffModuleV2(movieDB, allBookings, bookingTotal,
                             allReviews, reviewTotal);
        } else if (mainChoice == 2) {
            runCustomerModuleV2(movieDB, allBookings, bookingTotal,
                                allReviews, reviewTotal);
        } else if (mainChoice == 3) {
            runCustomerRegister();
        } else if (mainChoice == 4) {
            runVIPModuleV2(movieDB, allBookings, bookingTotal,
                           allReviews, reviewTotal);
        } else if (mainChoice == 0) {
            saveMoviesToFile(movieDB);
            rewriteBookingsFile(allBookings, bookingTotal);
            cout << "\n  Data saved successfully.\n";
            cout << "  Thank you for using Movie Database System. Goodbye!\n";
            printLine(44);
        }
    }
    delete[] allBookings;
    allBookings = NULL;
    delete[] allReviews;
    allReviews = NULL;
    return 0;
}
