void staffDeleteCustomerAccount(string targetUser) {
    ifstream file("customer_accounts.txt");
    if (!file.is_open()) {
        cout << "  Cannot open file.\n";
        return;
    }
    string lines[100];
    int lineCount = 0;
    string line;
    while (getline(file, line) && lineCount < 100) {
        if (!line.empty()) {
            lines[lineCount++] = line;
        }
    }
    file.close();
    bool found = false;
    ofstream out("customer_accounts.txt");
    for (int i = 0; i < lineCount; i++) {
        istringstream ss(lines[i]);
        string uname;
        getline(ss, uname, '|');
        if (uname == targetUser) {
            found = true;
            continue;  
        }
        out << lines[i] << "\n";
    }
    out.close();
    if (found) cout << "  Account '" << targetUser << "' removed.\n";
    else        cout << "  Username '" << targetUser << "' not found.\n";
}
