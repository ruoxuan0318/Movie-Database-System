void staffMovieReviewReport(ReviewData* reviews, int reviewTotal, MovieList& list) {
    cout << "\n--- Movie Review Report ---\n";
    if (reviewTotal == 0) {
        cout << "  No reviews available.\n";
        return;
    }
    int   mIDs[200];
    double mStars[200];
    int   mCount[200];
    int   unique = 0;
    for (int i = 0; i < reviewTotal; i++) {
        bool found = false;
        for (int j = 0; j < unique; j++) {
            if (mIDs[j] == reviews[i].movieID) {
                mStars[j] += reviews[i].stars;
                mCount[j]++;
                found = true;
                break;
            }
        }
        if (!found && unique < 200) {
            mIDs[unique]   = reviews[i].movieID;
            mStars[unique] = reviews[i].stars;
            mCount[unique] = 1;
            unique++;
        }
    }
    cout << left << setw(8)  << "Movie ID"
         << setw(35) << "Title"
         << setw(10) << "Reviews"
         << "Avg Stars\n";
    cout << string(58, '-') << "\n";
    for (int i = 0; i < unique; i++) {
        MovieNode* m = list.findMovie(mIDs[i]);
        string title = (m != NULL) ? m->data.title : "Unknown";
        double avg   = mStars[i] / mCount[i];
        cout << left << setw(8)  << mIDs[i]
             << setw(35) << title
             << setw(10) << mCount[i]
             << fixed << setprecision(1) << avg << " / 5.0\n";
    }
    cout << string(58, '-') << "\n";
}
