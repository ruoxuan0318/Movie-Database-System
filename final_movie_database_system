int stringToInt(string s) {
    int result = 0;
    int sign = 1;
    int i = 0;
    if (s.length() > 0 && s[0] == '-') {
        sign = -1;
        i = 1;
    }
    for (; i < (int)s.length(); i++) {
        if (s[i] >= '0' && s[i] <= '9') {
            result = result * 10 + (s[i] - '0');
        }
    }
    return result * sign;
}
double stringToDouble(string s) {
    double result = 0.0;
    double fraction = 0.0;
    double divisor = 10.0;
    int sign = 1;
    int i = 0;
    bool afterDot = false;
    if (s.length() > 0 && s[0] == '-') {
        sign = -1;
        i = 1;
    }
    for (; i < (int)s.length(); i++) {
        if (s[i] == '.') {
            afterDot = true;
            continue;
        }
        if (s[i] >= '0' && s[i] <= '9') {
            if (!afterDot) {
                result = result * 10 + (s[i] - '0');
            } else {
                fraction += (s[i] - '0') / divisor;
                divisor *= 10;
            }
        }
    }
    return (result + fraction) * sign;
}
class MovieNode {
public:
    MovieData data;
    MovieNode* next; 
    MovieNode* prev; 
    MovieNode(int id, string title, string genre, double price, double rating) {
        data.movieID = id;
        data.title = title;
        data.genre = genre;
        data.price = price;
        data.rating = rating;
        next = NULL;
        prev = NULL;
    }
};
class MovieList {
private:
    MovieNode* head;
    MovieNode* tail;
    int count;
public:
    MovieList() {
        head = NULL;
        tail = NULL;
        count = 0;
    }
    ~MovieList() {
        MovieNode* curr = head;
        while (curr != NULL) {
            MovieNode* temp = curr->next;
            delete curr;
            curr = temp;
        }
        head = NULL;
        tail = NULL;
        count = 0;
    }
    MovieNode* getHead() { return head; }
    MovieNode* getTail() { return tail; }
    int getCount()       { return count; }
    void setHead(MovieNode* h) { head = h; }
    void setTail(MovieNode* t) { tail = t; }
    void insertMovie(int id, string title, string genre, double price, double rating) {
        MovieNode* temp = new MovieNode(id, title, genre, price, rating);
        if (head == NULL) {
            head = temp;
            head->next = NULL;
            head->prev = NULL; 
            tail = head;       
        } else {
            
            tail->next = temp; 
            temp->prev = tail; 
            
            tail = temp;       
        }
        count++;
    }
    bool deleteMovie(int targetID) {
        MovieNode* curr = head;
        while (curr != NULL) {
            if (curr->data.movieID == targetID) {
                if (curr == head && curr == tail) {
                    head = NULL;
                    tail = NULL;
                } else if (curr == head) {
                    head = head->next;
                    if (head != NULL) head->prev = NULL;
                } else if (curr == tail) {
                    tail = tail->prev;
                    if (tail != NULL) tail->next = NULL;
                } else {
                    curr->prev->next = curr->next;
                    curr->next->prev = curr->prev;
                }
                delete curr;
                count--;
                return true;
            }
            curr = curr->next;
        }
        return false;
    }
    MovieNode* findMovie(int targetID) {
        MovieNode* curr = head;
        while (curr != NULL) {
            if (curr->data.movieID == targetID)
                return curr;
            curr = curr->next;
        }
        return NULL;
    }
    MovieNode* findMovieByTitle(string keyword) {
        MovieNode* curr = head;
        while (curr != NULL) {
            if (curr->data.title.find(keyword) != string::npos)
                return curr;
            curr = curr->next;
        }
        return NULL;
    }
    void displayAll() {
        if (head == NULL) {
            cout << "  No movies in the database.\n";
            return;
        }
        cout << "\n";
        cout << left << setw(8)  << "ID"
             << setw(35) << "Title"
             << setw(15) << "Genre"
             << setw(10) << "Price(RM)"
             << "Rating\n";
        cout << string(75, '-') << "\n";
        MovieNode* curr = head;
        while (curr != NULL) {
            cout << left << setw(8)  << curr->data.movieID
                 << setw(35) << curr->data.title
                 << setw(15) << curr->data.genre
                 << setw(10) << fixed << setprecision(2) << curr->data.price
                 << curr->data.rating << "/10\n";
            curr = curr->next;
        }
        cout << string(75, '-') << "\n";
        cout << "Total: " << count << " movies\n";
    }
    void displayByGenre(string genre) {
        cout << "\n--- Movies in genre: " << genre << " ---\n";
        cout << left << setw(8)  << "ID"
             << setw(35) << "Title"
             << setw(10) << "Price(RM)"
             << "Rating\n";
        cout << string(60, '-') << "\n";
        MovieNode* curr = head;
        int found = 0;
        while (curr != NULL) {
            if (curr->data.genre == genre) {
                cout << left << setw(8)  << curr->data.movieID
                     << setw(35) << curr->data.title
                     << setw(10) << fixed << setprecision(2) << curr->data.price
                     << curr->data.rating << "/10\n";
                found++;
            }
            curr = curr->next;
        }
        if (found == 0)
            cout << "  No movies found for this genre.\n";
        cout << string(60, '-') << "\n";
    }
};
class MovieAlgorithm {
private:
    static void Swap(MovieNode* x, MovieNode* y) {
        MovieData temp = x->data;
        x->data = y->data;
        y->data = temp;
    }
    static MovieNode* partition(MovieNode* left, MovieNode* right, int mode) {
        MovieNode* midNode = left;
        MovieNode* temp = left;
        int n = 0;
        while (temp != right->next) {
            n++;
            temp = temp->next;
        }
        for (int k = 0; k < n / 2; k++) {
            midNode = midNode->next;
        }
        
        Swap(left, midNode);
        
        MovieData pivot = left->data;
        MovieNode* pivotpos = left;
        
        for (MovieNode* i = left->next; i != right->next; i = i->next) {
            bool compare = false;
            if (mode == 1) {
                if (i->data.price < pivot.price) compare = true;
            } else if (mode == 2) {
                if (i->data.rating > pivot.rating) compare = true;
            } else if (mode == 3) {
                if (i->data.title < pivot.title) compare = true;
            } else if (mode == 4) {
                if (i->data.genre < pivot.genre) compare = true;
            }
            if (compare) {
                
                pivotpos = pivotpos->next;
                Swap(pivotpos, i);
            }
        }
        Swap(left, pivotpos);
        return pivotpos;
    }
    static void quickSort(MovieNode* left, MovieNode* right, int mode) {
        MovieNode* pivotpos;
        if (left != NULL && right != NULL && left != right && left != right->next) {
            pivotpos = partition(left, right, mode);
            quickSort(left, pivotpos->prev, mode);
            quickSort(pivotpos->next, right, mode);
        }
    }
public:
    static void sortMovies(MovieList& list, int mode) {
        if (list.getHead() == NULL) return;
        quickSort(list.getHead(), list.getTail(), mode);
        if (mode == 1)
            cout << "  Sorted by price (low to high).\n";
        else if (mode == 2)
            cout << "  Sorted by rating (high to low).\n";
        else if (mode == 3)
            cout << "  Sorted by title (A to Z).\n";
        else if (mode == 4)
            cout << "  Sorted by genre (A to Z).\n";
    }
    static MovieNode* binarySearchByID(MovieList& list, int targetID) {
        if (list.getHead() == NULL) return NULL;
        int n = list.getCount();
        MovieNode** arr = new MovieNode*[n];
        MovieNode* curr = list.getHead();
        for (int i = 0; i < n; i++) {
            arr[i] = curr;
            curr = curr->next;
        }
        for (int i = 0; i < n - 1; i++) {
            for (int j = 0; j < n - i - 1; j++) {
                if (arr[j]->data.movieID > arr[j+1]->data.movieID) {
                    MovieNode* temp = arr[j];
                    arr[j] = arr[j+1];
                    arr[j+1] = temp;
                }
            }
        }
        int first = 0;
        int last = n - 1;
        int found = 0;
        int mid;
        
        while ((found == 0) && (first <= last)) {
            mid = (first + last) / 2;
            if (targetID == arr[mid]->data.movieID) {
                found = 1;
            } else {
                if (targetID < arr[mid]->data.movieID) {
                    last = mid - 1;
                } else {
                    first = mid + 1;
                }
            }
        }
        MovieNode* result = NULL;
        if (found) {
            result = arr[mid];
        }
        delete[] arr;
        return result;
    }
};
