// --- movies.txt ---

void saveMoviesToFile(MovieList& list) {
    ofstream file("movies.txt");
    if (!file.is_open()) {
        cout << "[ERROR] Cannot open movies.txt for writing.\n";
        return;
    }
    MovieNode* curr = list.getHead();
    while (curr != NULL) {
        file << curr->data.movieID << "|"
             << curr->data.title   << "|"
             << curr->data.genre   << "|"
             << curr->data.price   << "|"
             << curr->data.rating  << "\n";
        curr = curr->next;
    }
    file.close();
}

void loadMoviesFromFile(MovieList& list) {
    ifstream file("movies.txt");
    if (!file.is_open()) return;

    string line;
    while (getline(file, line)) {
        if (line.empty()) continue;
        istringstream ss(line);
        string part;
        int id;
        string title, genre;
        double price, rating;

        try {
            getline(ss, part, '|'); id     = stoi(part);
            getline(ss, title,  '|');
            getline(ss, genre,  '|');
            getline(ss, part,   '|'); price  = stod(part);
            getline(ss, part,   '|'); rating = stod(part);
            list.insertMovie(id, title, genre, price, rating);
        } catch (...) {
            // skip bad lines
        }
    }
    file.close();
}

// --- bookings.txt ---

void saveBookingToFile(BookingData& b) {
    ofstream file("bookings.txt", ios::app);
    if (!file.is_open()) {
        cout << "[ERROR] Cannot open bookings.txt.\n";
        return;
    }
    file << b.bookingID    << "|"
         << b.customerName << "|"
         << b.movieID      << "|"
         << b.movieTitle   << "|"
         << b.quantity     << "|"
         << fixed << setprecision(2) << b.totalPrice << "\n";
    file.close();
}

void loadBookingsFromFile(BookingData* arr, int& total) {
    ifstream file("bookings.txt");
    if (!file.is_open()) return;

    string line;
    while (getline(file, line) && total < 200) {
        if (line.empty()) continue;
        istringstream ss(line);
        string part;
        try {
            getline(ss, part, '|'); arr[total].bookingID    = stoi(part);
            getline(ss, arr[total].customerName, '|');
            getline(ss, part, '|'); arr[total].movieID      = stoi(part);
            getline(ss, arr[total].movieTitle, '|');
            getline(ss, part, '|'); arr[total].quantity     = stoi(part);
            getline(ss, part, '|'); arr[total].totalPrice   = stod(part);
            total++;
        } catch (...) {
            // skip bad lines
        }
    }
    file.close();
}

void rewriteBookingsFile(BookingData* arr, int total) {
    ofstream file("bookings.txt");
    if (!file.is_open()) return;
    for (int i = 0; i < total; i++) {
        file << arr[i].bookingID    << "|"
             << arr[i].customerName << "|"
             << arr[i].movieID      << "|"
             << arr[i].movieTitle   << "|"
             << arr[i].quantity     << "|"
             << fixed << setprecision(2) << arr[i].totalPrice << "\n";
    }
    file.close();
}

// --- staff_accounts.txt ---

bool verifyStaffLogin(string uname, string pass) {
    ifstream file("staff_accounts.txt");
    if (!file.is_open()) return false;
    string line;
    while (getline(file, line)) {
        if (line.empty()) continue;
        istringstream ss(line);
        string u, p;
        getline(ss, u, '|');
        getline(ss, p, '|');
        if (u == uname && p == pass) {
            file.close();
            return true;
        }
    }
    file.close();
    return false;
}

