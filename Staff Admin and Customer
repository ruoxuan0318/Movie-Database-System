class User {
protected:
    string username;
    string password;
public:
    User(string u, string p) {
        username = u;
        password = p;
    }
    virtual ~User() {}
    string getUsername() { return username; }
    string getPassword() { return password; }
    virtual void showMenu() = 0;  
};
class Logger {
public:
    virtual ~Logger() {}
    void logAction(string user, string action) {
        cout << "[LOG] " << user << " -> " << action << "\n";
    }
    void logError(string msg) {
        cout << "[ERROR] " << msg << "\n";
    }
};
