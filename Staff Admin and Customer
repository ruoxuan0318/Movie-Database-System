// =============================================================
// BASE CLASS 1: User - parent for StaffAdmin and Customer
// =============================================================

class User {
protected:
    string username;
    string password;
public:
    User(string u, string p) {
        username = u;
        password = p;
    }
    virtual ~User() {}

    string getUsername() { return username; }
    string getPassword() { return password; }

    virtual void showMenu() = 0;  // pure virtual
};


// =============================================================
// BASE CLASS 2: Logger - for recording actions
// =============================================================

class Logger {
public:
    virtual ~Logger() {}

    void logAction(string user, string action) {
        cout << "[LOG] " << user << " -> " << action << "\n";
    }

    void logError(string msg) {
        cout << "[ERROR] " << msg << "\n";
    }
};


