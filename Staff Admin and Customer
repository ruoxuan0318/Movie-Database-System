void showStaffDetails(const StaffAdmin& s) {
    cout << "\n--- Staff Details (Friend Function) ---\n";
    cout << "Username    : " << s.username << "\n";
    cout << "Role        : " << s.role << "\n";
    cout << "Access Level: " << s.accessLevel << "\n";
    cout << "---------------------------------------\n";
}
void showCustomerPoints(const Customer& c) {
    cout << "\n--- Customer Points Info (Friend Function) ---\n";
    cout << "Username     : " << c.username << "\n";
    cout << "Loyalty Pts  : " << c.loyaltyPoints << "\n";
    cout << "Total Tickets: " << c.totalTickets << "\n";
    cout << "----------------------------------------------\n";
}
void transferPoints(Customer& from, VIPCustomer& to) {
    cout << "\n--- Transfer Points (Friend Function) ---\n";
    to.totalTickets  = from.totalTickets;
    to.loyaltyPoints = from.loyaltyPoints + 200.0;
    cout << "Points from '" << from.username << "' transferred to VIP account.\n";
    cout << "New VIP balance: " << to.loyaltyPoints << " points\n";
    cout << "-----------------------------------------\n";
}
void systemSnapshot(const StaffAdmin& s, const Customer& c) {
    cout << "\n--- System Snapshot (Friend Function) ---\n";
    cout << "Last Staff  : " << s.username << " (" << s.role << ")\n";
    cout << "Last Customer: " << c.username << "\n";
    cout << "-----------------------------------------\n";
}
void saveMoviesToFile(MovieList& list) {
    ofstream file("movies.txt");
    if (!file.is_open()) {
        cout << "[ERROR] Cannot open movies.txt for writing.\n";
        return;
    }
    MovieNode* curr = list.getHead();
    while (curr != NULL) {
        file << curr->data.movieID << "|"
             << curr->data.title   << "|"
             << curr->data.genre   << "|"
             << curr->data.price   << "|"
             << curr->data.rating  << "\n";
        curr = curr->next;
    }
    file.close();
}
