// ==========================================
// 2. DYNAMIC NON-PRIMITIVE DATA STRUCTURE (DNP)
// Guideline: Strictly NO STL headers. Manual memory management (new/delete) required.
// Implementation: Doubly Linked List for Movie Records
// ==========================================

// Node definition for movie link structure
class MovieNode {
public:
    MovieData data;
    MovieNode* next;
    MovieNode* prev;

    MovieNode(int id, string t, double p, double r) {
        data.movieID = id;
        data.title = t;
        data.price = p;
        data.rating = r;
        next = NULL;
        prev = NULL;
    }
};

// Doubly Linked List manager class
class MovieLinkedList {
private:
    MovieNode* head;
    MovieNode* tail;
public:
    MovieLinkedList() {
        head = NULL;
        tail = NULL;
    }

    // Destructor: Recycles all dynamically allocated node memories (Manual dynamic allocation check)
    ~MovieLinkedList() {
        MovieNode* current = head;
        while (current != NULL) {
            MovieNode* nextNode = current->next;
            delete current;
            current = nextNode;
        }
    }

    // Appends a new movie record to the tail of the linked list
    void insertMovie(int id, string t, double p, double r) {
        MovieNode* newNode = new MovieNode(id, t, p, r);
        if (head == NULL) {
            head = tail = newNode;
        } else {
            tail->next = newNode;
            newNode->prev = tail;
            tail = newNode;
        }
    }

    // Displays all available movies in a clean tabular view
    void displayAllMovies() {
        if (head == NULL) {
            cout << "No movies available in the database.\n";
            return;
        }
        MovieNode* current = head;
        cout << "---------------------------------------------------------\n";
        cout << left << setw(10) << "MovieID" << setw(35) << "Title" << setw(10) << "Price" << setw(10) << "Rating" << endl;
        cout << "---------------------------------------------------------\n";
        while (current != NULL) {
            cout << left << setw(10) << current->data.movieID 
                 << setw(35) << current->data.title 
                 << setw(10) << fixed << setprecision(2) << current->data.price 
                 << setw(10) << current->data.rating << endl;
            current = current->next;
        }
        cout << "---------------------------------------------------------\n";
    }

    // Getter function returning the head pointer (required for upcoming sorting/searching routines)
    MovieNode* getHead() { return head; }
};

