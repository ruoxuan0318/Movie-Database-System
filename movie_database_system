// ==========================================
// 2. MANUAL LINKED LIST (NO STL)
// ==========================================

// basic node for our doubly linked list structure
class MovieNode {
public:
    MovieData data;
    MovieNode* next;
    MovieNode* prev;

    // constructor to make a node quickly
    MovieNode(int id, string t, double p, double r) {
        data.movieID = id;
        data.title = t;
        data.price = p;
        data.rating = r;
        next = NULL;
        prev = NULL;
    }
};

// linked list class to handle node changes
class MovieLinkedList {
private:
    MovieNode* head;
    MovieNode* tail;
public:
    MovieLinkedList() {
        head = NULL;
        tail = NULL;
    }

    // destructor to wipe memory and prevent leaks
    ~MovieLinkedList() {
        MovieNode* current = head;
        while (current != NULL) {
            MovieNode* nextNode = current->next;
            delete current; // free dynamic allocation
            current = nextNode;
        }
    }

    // push new movie to the back of list
    void insertMovie(int id, string t, double p, double r) {
        MovieNode* newNode = new MovieNode(id, t, p, r);
        if (head == NULL) {
            head = tail = newNode;
        } else {
            tail->next = newNode;
            newNode->prev = tail;
            tail = newNode;
        }
    }

    // scans list one by one to find the right ID pointer
    MovieNode* findMovieByID(int id) {
        MovieNode* current = head;
        while (current != NULL) {
            if (current->data.movieID == id) return current;
            current = current->next;
        }
        return NULL;
    }

    // unlinks node pointers manually and calls delete
    bool deleteMovieByID(int id) {
        MovieNode* target = findMovieByID(id);
        if (target == NULL) return false;

        // check if it is head node
        if (target == head) {
            head = target->next;
            if (head != NULL) head->prev = NULL;
            else tail = NULL; // table is empty now
        }
        // check if it is tail node
        else if (target == tail) {
            tail = target->prev;
            if (tail != NULL) tail->next = NULL;
        }
        // middle node re-linking logic
        else {
            target->prev->next = target->next;
            target->next->prev = target->prev;
        }

        delete target; // release memory heap
        return true;
    }

    // draws standard plain text table view on screen
    void displayAllMovies() {
        if (head == NULL) {
            cout << "No movies available in the database.\n";
            return;
        }
        MovieNode* current = head;
        cout << "---------------------------------------------------------\n";
        cout << left << setw(10) << "MovieID" << setw(35) << "Title" << setw(10) << "Price" << setw(10) << "Rating" << endl;
        cout << "---------------------------------------------------------\n";
        while (current != NULL) {
            cout << left << setw(10) << current->data.movieID 
                 << setw(35) << current->data.title 
                 << setw(10) << fixed << setprecision(2) << current->data.price 
                 << setw(10) << current->data.rating << endl;
            current = current->next;
        }
        cout << "---------------------------------------------------------\n";
    }

    // returns start pointer for sorting algorithms later
    MovieNode* getHead() { return head; }
};

