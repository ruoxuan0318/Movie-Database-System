// ==========================================
// 4. FILE LOADER MODULE
// ==========================================

void loadMoviesFromFile(MovieLinkedList& list) {
    ifstream file("movies_database.txt");
    if (!file.is_open()) {
        cout << "[ERROR] Failed to open movies_database.txt. Make sure it is in the same folder!\n";
        return;
    }

    string line;
    int count = 0;
    while (getline(file, line)) {
        if (line.empty()) continue;
        
        stringstream ss(line);
        string id_str, title, price_str, rating_str;

        // split text components by using '|' symbol
        getline(ss, id_str, '|');
        getline(ss, title, '|');
        getline(ss, price_str, '|');
        getline(ss, rating_str, '|');

        // text conversion routines
        int id = stoi(id_str);
        double price = stod(price_str);
        double rating = stod(rating_str);

        // put into our link nodes directly
        list.insertMovie(id, title, price, rating);
        count++;
    }
    file.close();
    cout << "[SUCCESS] Successfully loaded " << count << " movie records from database file.\n";
}


